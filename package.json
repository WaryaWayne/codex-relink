{
  "name": "codex-relink",
  "version": "0.0.1",
  "description": "Find Codex chats for the current directory and print resume commands.",
  "type": "module",
  "bin": {
    "codex-relink": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "effect-tsgo patch"
  },
  "keywords": [
    "codex",
    "cli",
    "resume",
    "chat",
    "find"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.66",
    "@effect/sql-sqlite-node": "4.0.0-beta.66",
    "@typescript/native-preview": "7.0.0-dev.20260515.1",
    "effect": "4.0.0-beta.66"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "6.0.3",
    "vitest": "^4.0.14",
    "@effect/tsgo": "0.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
